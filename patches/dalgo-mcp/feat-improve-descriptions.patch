@@ -7,21 +7,35 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_list_notifications() -> str:
-        """List recent notifications for the current user."""
+        """List recent notifications for the current user (pipeline failures, sync alerts, system messages).
+
+        Use when the user wants to check recent alerts or activity on their account.
+        Example: "Do I have any notifications?" or "What alerts have I received about my pipelines?"
+        Note: Returns notification IDs needed for dalgo_mark_notifications_read.
+        """
         client: DalgoClient = await get_client()
         resp = await client.get("/api/notifications/v1")
         return format_response(resp)
 
     @app.tool()
     async def dalgo_get_unread_count() -> str:
-        """Get the count of unread notifications."""
+        """Get the count of unread notifications for the current user.
+
+        Use when you need a quick check of whether the user has unread alerts, without fetching full notification details.
+        Example: "How many unread notifications do I have?" or as a lightweight check before calling dalgo_list_notifications.
+        Note: Returns a count only — use dalgo_list_notifications to see the actual notification content.
+        """
         client: DalgoClient = await get_client()
         resp = await client.get("/api/notifications/unread_count")
