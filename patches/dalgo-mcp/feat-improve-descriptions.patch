         Args:
             connection_id: The Airbyte connection ID.
@@ -36,7 +49,11 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_get_connection_catalog(connection_id: str) -> str:
-        """Get the stream catalog for an Airbyte connection (selected streams and sync modes).
+        """Get the stream catalog for an Airbyte connection — which tables/streams are selected and their sync modes.
+
+        Use when the user wants to know what data is being synced, or to verify a specific form/table is included.
+        Example: "Is the health_screening stream included in our Kobo connection?" or "What tables does this sync bring in?"
+        Note: Returns selected streams with their sync mode (full_refresh or incremental) and primary keys.
 
         Args:
             connection_id: The Airbyte connection ID.
