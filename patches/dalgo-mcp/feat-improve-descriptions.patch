+        """Get configuration details of a specific Airbyte connection.
+
+        Use when the user wants to inspect a connection's sync mode, selected streams, or schedule.
+        Example: "What streams does our Kobo connection sync?" or "Is the beneficiary sync incremental or full refresh?"
+        Note: Use dalgo_list_connections first to find the connection_id.
 
         Args:
             connection_id: The Airbyte connection ID.
@@ -25,7 +34,11 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_get_sync_history(connection_id: str) -> str:
-        """Get sync run history for an Airbyte connection.
+        """Get the sync run history for an Airbyte connection, including status and row counts.
