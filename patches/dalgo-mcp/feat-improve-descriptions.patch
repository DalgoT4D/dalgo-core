diff --git a/src/dalgo_mcp/tools/charts.py b/src/dalgo_mcp/tools/charts.py
index 1f74908..4b489c7 100644
--- a/src/dalgo_mcp/tools/charts.py
+++ b/src/dalgo_mcp/tools/charts.py
@@ -7,14 +7,23 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_list_charts() -> str:
-        """List all charts in the organization."""
+        """List all charts in the organization.
+
+        Use when the user asks what charts exist, or to find a chart_id for viewing, editing, or deleting.
+        Example: "What charts do we have?" or "Is there already a chart showing monthly beneficiary registrations?"
+        Note: Returns chart IDs needed for dalgo_get_chart, dalgo_get_chart_data, and dalgo_update_chart.
+        """
         client: DalgoClient = await get_client()
         resp = await client.get("/api/charts/")
         return format_response(resp)
 
     @app.tool()
     async def dalgo_get_chart(chart_id: str) -> str:
-        """Get details of a specific chart.
+        """Get configuration details of a specific chart, including its SQL query, type, and dashboard assignment.
+
+        Use when the user wants to inspect or understand a specific chart's setup.
+        Example: "What SQL query does the 'beneficiaries by district' chart use?" or "Which dashboard is this chart on?"
+        Note: Use dalgo_list_charts first to find the chart_id.
 
         Args:
             chart_id: The chart ID.
@@ -25,7 +34,11 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_create_chart(chart_data: dict) -> str:
-        """Create a new chart.
+        """Create a new chart with a SQL query, chart type, and optional dashboard assignment.
+
+        Use when the user wants to add a new visualization to a dashboard.
+        Example: "Create a bar chart showing monthly beneficiary registrations grouped by district."
+        Note: Use dalgo_get_table_columns to understand available columns before writing the SQL query.
 
         Args:
             chart_data: Chart configuration dict with title, SQL query, chart type, and dashboard assignment.
@@ -36,7 +49,11 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_update_chart(chart_id: str, chart_data: dict) -> str:
-        """Update an existing chart.
+        """Update an existing chart's title, SQL query, type, or dashboard assignment.
+
+        Use when the user wants to edit a chart — fix a query, change the chart type, or move it to a different dashboard.
+        Example: "Update the beneficiary chart to also group by gender" or "Change this chart from a bar chart to a line chart."
+        Note: Fetch the current config with dalgo_get_chart first so you only change what the user requested.
 
         Args:
             chart_id: The chart ID.
@@ -48,7 +65,11 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_delete_chart(chart_id: str) -> str:
-        """Delete a chart.
+        """Delete a chart permanently.
+
+        Use only when the user explicitly wants to remove a chart.
+        Example: "Delete the old 'pilot cohort' chart — the program has ended."
+        Note: Confirm with the user before deleting. This is irreversible.
 
         Args:
             chart_id: The chart ID.
@@ -59,7 +80,11 @@ def register(app: FastMCP, get_client):
 
     @app.tool()
     async def dalgo_get_chart_data(chart_id: str) -> str:
-        """Execute a chart's query and return the resulting data.
+        """Execute a chart's underlying SQL query and return the resulting data rows.
+
+        Use when the user wants to see the actual numbers behind a chart, not just the visualization.
+        Example: "What are the current numbers on the district breakdown chart?" or "Give me the data from the monthly registrations chart."
+        Note: Returns the raw query result — useful for spot-checking chart accuracy or exporting values.
 
         Args:
             chart_id: The chart ID.
diff --git a/src/dalgo_mcp/tools/connections.py b/src/dalgo_mcp/tools/connections.py
